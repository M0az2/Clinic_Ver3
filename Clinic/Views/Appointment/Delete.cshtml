@model Clinic.Models.Appointment
@{
    ViewData["Title"] = "Delete Appointment";
}

<h2>Delete Appointment</h2>

<h4>Are you sure you want to delete this appointment?</h4>
<dl class="row">
    <dt class="col-sm-3">Date & Time</dt>
    <dd class="col-sm-9">@Model.AppointmentDate.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Patient</dt>
    <dd class="col-sm-9">@Model.Patient.FullName</dd>
    <dt class="col-sm-3">Doctor</dt>
    <dd class="col-sm-9">@Model.Doctor.FullName</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

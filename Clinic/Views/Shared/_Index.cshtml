

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @RenderSection("Styles",false)
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top">
        <div class="container">
            <a class="navbar-brand" href="#">
                <i class="fas fa-heartbeat me-2"></i>Harmony Medical
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Patient" asp-action="Index">Patients</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#services">Services</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Doctor" asp-action="Index">Doctors</a>
                    </li> 
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Appointment" asp-action="Index">Appointment</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>
                    @using System.Security.Claims
                    @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                    {
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-outline-danger" asp-controller="Account" asp-action="Login" role="button">
                                Logout
                            </a>
                        </li>
                    }
                    else
                    {
                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login" role="button">
                            Login
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary" href="signup.html" role="button">
                            Sign Up
                        </a>
                    </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- End Navigation-->
    
    <div>
        @RenderBody()
    </div>

        @*
        
    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4 mb-lg-0">
